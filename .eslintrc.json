{
  "env": {
    "browser": true,
    "es2020": true
  },
  "parserOptions": {
    "ecmaVersion": 2020
  },
  "globals": {
    "supabase": "readonly",
    "Chart": "readonly",
    "html2canvas": "readonly"
  },
  "rules": {
    "no-undef": "warn",
    "no-unused-vars": "warn",
    "no-console": "off",
    "semi": ["warn", "always"],
    "no-var": "off",
    "eqeqeq": "off"
  }
}
